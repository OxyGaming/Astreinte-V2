generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Contact {
  id            String         @id @default(cuid())
  nom           String
  role          String
  categorie     String
  telephone     String
  telephoneAlt  String?
  note          String?
  disponibilite String?
  /// Rattachement optionnel à un secteur de référence (évolution métier)
  secteurId     String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  fiches        FicheContact[]
  secteur       Secteur?       @relation(fields: [secteurId], references: [id], onDelete: SetNull)
}

model Secteur {
  id          String         @id @default(cuid())
  slug        String         @unique
  nom         String
  ligne       String
  trajet      String
  description String
  pointsAcces String
  procedures  String
  pn          String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  fiches      FicheSecteur[]
  postes      PosteSecteur[]
  contacts    Contact[]
}

model Fiche {
  id               String         @id @default(cuid())
  slug             String         @unique
  numero           Int            @unique
  titre            String
  categorie        String
  priorite         String
  mnemonique       String?
  resume           String
  etapes           String
  references       String?
  avisObligatoires String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  featured         Boolean        @default(false)
  contacts         FicheContact[]
  secteurs         FicheSecteur[]
}

model FicheContact {
  ficheId   String
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  fiche     Fiche   @relation(fields: [ficheId], references: [id], onDelete: Cascade)

  @@id([ficheId, contactId])
}

model FicheSecteur {
  ficheId   String
  secteurId String
  secteur   Secteur @relation(fields: [secteurId], references: [id], onDelete: Cascade)
  fiche     Fiche   @relation(fields: [ficheId], references: [id], onDelete: Cascade)

  @@id([ficheId, secteurId])
}

model Mnemonique {
  id          String   @id @default(cuid())
  acronyme    String
  titre       String
  description String
  lettres     String
  contexte    String?
  couleur     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Abreviation {
  id         String   @id @default(cuid())
  sigle      String   @unique
  definition String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Poste {
  id               String             @id @default(cuid())
  slug             String             @unique
  nom              String
  typePoste        String
  lignes           String
  adresse          String
  horaires         String
  electrification  String
  systemeBlock     String
  annuaire         String
  circuitsVoie     String
  pnSensibles      String
  particularites   String
  proceduresCles   String
  dbc              String?
  rex              String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  secteurs         PosteSecteur[]
  proceduresMetier PosteProcedure[]
  sessionsMetier   SessionProcedure[]
}

model PosteSecteur {
  posteId   String
  secteurId String
  secteur   Secteur @relation(fields: [secteurId], references: [id], onDelete: Cascade)
  poste     Poste   @relation(fields: [posteId], references: [id], onDelete: Cascade)

  @@id([posteId, secteurId])
}

model Procedure {
  id            String             @id @default(cuid())
  slug          String             @unique
  titre         String
  typeProcedure String
  description   String?
  version       String             @default("1.0")
  etapes        String
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  postes        PosteProcedure[]
  sessions      SessionProcedure[]
}

model PosteProcedure {
  id          String    @id @default(cuid())
  posteId     String
  procedureId String
  ordre       Int       @default(0)
  procedure   Procedure @relation(fields: [procedureId], references: [id], onDelete: Cascade)
  poste       Poste     @relation(fields: [posteId], references: [id], onDelete: Cascade)

  @@unique([posteId, procedureId])
}

model SessionProcedure {
  id                String                  @id @default(cuid())
  procedureId       String
  procedureVersion  String
  procedureSnapshot String
  posteId           String
  posteSlug         String
  agentNom          String?
  statut            String                  @default("en_cours")
  etapeIndex        Int                     @default(0)
  etat              String                  @default("{\"etapes\":{}}")
  synthese          String?
  startedAt         DateTime                @default(now())
  completedAt       DateTime?
  eventsArchived    Boolean                 @default(false)
  eventsArchivedAt  DateTime?
  poste             Poste                   @relation(fields: [posteId], references: [id])
  procedure         Procedure               @relation(fields: [procedureId], references: [id])
  events            SessionProcedureEvent[]

  @@index([posteSlug])
  @@index([statut])
  @@index([eventsArchived, statut, completedAt])
}

model SessionProcedureEvent {
  id         String           @id @default(cuid())
  sessionId  String
  sequence   Int
  type       String
  etapeId    String?
  actionId   String?
  valeur     String?
  payload    String
  actorNom   String?
  occurredAt DateTime         @default(now())
  session    SessionProcedure @relation(fields: [sessionId], references: [id])

  @@unique([sessionId, sequence])
  @@index([sessionId, occurredAt])
  @@index([type, occurredAt])
  @@index([actionId])
}

model SessionProcedureEventArchive {
  id         String   @id
  sessionId  String
  sequence   Int
  type       String
  etapeId    String?
  actionId   String?
  valeur     String?
  payload    String
  actorNom   String?
  occurredAt DateTime
  archivedAt DateTime @default(now())

  @@unique([sessionId, sequence])
  @@index([sessionId])
  @@index([occurredAt])
  @@index([actionId])
}

model AccesRail {
  id          String   @id @default(cuid())
  ligne       String
  pk          String
  type        String?
  identifiant String?
  nomAffiche  String
  nomComplet  String
  latitude    Float
  longitude   Float
  description String?
  source      String   @default("KML")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ligne])
  @@index([pk])
}

model User {
  id          String            @id @default(cuid())
  username    String            @unique
  password    String
  nom         String
  prenom      String
  role        String            @default("USER")
  actif       Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  email       String?           @unique
  status      String            @default("approved")
  poste       String?
  motif       String?
  actionLogs  FicheActionLog[]
  commentLogs FicheCommentLog[]
  sessions    FicheSession[]
}

model FicheSession {
  id              String            @id @default(cuid())
  ficheSlug       String
  ficheTitre      String
  createdByUserId String
  startedAt       DateTime          @default(now())
  endedAt         DateTime?
  status          String            @default("active")
  actionLogs      FicheActionLog[]
  commentLogs     FicheCommentLog[]
  createdBy       User              @relation(fields: [createdByUserId], references: [id])

  @@index([ficheSlug])
  @@index([status])
}

model FicheActionLog {
  id          String       @id @default(cuid())
  sessionId   String
  ficheSlug   String
  etapeOrdre  Int
  actionIndex Int
  actionLabel String
  userId      String
  timestamp   DateTime     @default(now())
  type        String
  user        User         @relation(fields: [userId], references: [id])
  session     FicheSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model FicheCommentLog {
  id        String       @id @default(cuid())
  sessionId String
  ficheSlug String
  userId    String
  timestamp DateTime     @default(now())
  message   String
  user      User         @relation(fields: [userId], references: [id])
  session   FicheSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  userId     String
  userNom    String
  action     String
  resource   String
  resourceId String
  detail     String?
  timestamp  DateTime @default(now())

  @@index([resource, resourceId])
  @@index([userId])
  @@index([timestamp])
}
