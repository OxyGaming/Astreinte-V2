# ─── Base de données ──────────────────────────────────────────────────────────
# Chemin vers le fichier SQLite
DATABASE_URL="file:./dev.db"

# ─── Secrets de session ───────────────────────────────────────────────────────
# OBLIGATOIRES en production. Générer avec :
#   openssl rand -base64 48
# Ces secrets signent les tokens de session. Ne jamais les partager ni les committer.

SESSION_SECRET="remplacez-par-une-valeur-aleatoire-longue"
ADMIN_SESSION_SECRET="remplacez-par-une-autre-valeur-aleatoire-longue"

# ─── Notes de déploiement ────────────────────────────────────────────────────
# En production derrière un reverse proxy (nginx/traefik) :
# - S'assurer que X-Forwarded-For est bien transmis par le proxy
# - Configurer HSTS sur le proxy : add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
# - NODE_ENV doit être défini à "production" (fait automatiquement par `next start`)
